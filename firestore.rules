/**
 * # Firestore Security Rules for OrdenaPro
 *
 * ## Core Philosophy
 * This ruleset enforces a role-based access control (RBAC) model combined with user ownership.
 * The two primary roles are 'Solicitante' (requester) and 'Compras' (purchasing team).
 * - **Solicitantes** can create purchase requests and can only view/manage documents they created.
 * - **Compras** members have broader permissions to view all requests and manage the lifecycle from request to purchase order.
 * - Access is determined at the document level, not on a per-field basis, to keep rules simple and performant.
 *
 * ## Data Structure
 * The structure uses top-level collections for primary data types like `userProfiles`, `purchaseRequests`, and `purchaseOrders`.
 * Items and comments are logically grouped in subcollections under their parent document.
 * A dedicated top-level `/roles/compras` collection is used as a fast, indexed lookup to verify a user's role, which is more performant and secure than checking a field on a user profile document.
 *
 * ## Key Security Decisions
 * - **Denormalization for Authorization**: To avoid slow and costly `get()` calls in rules, authorization-critical data like `requesterId` and `issuedByUserId` is denormalized (copied) onto the documents and subcollections being secured.
 * - **Role-Based Access**: A separate `/roles/compras/{userId}` collection provides a fast way to check if a user belongs to the 'Compras' team using `exists()`. This collection is intended to be managed by backend Cloud Functions, so client-side writes are disabled.
 * - **User Privacy**: Users can only access their own `/userProfiles/{userId}` document. Listing all user profiles is strictly forbidden to prevent user data enumeration.
 * - **Secure Subcollection Access**: Access to subcollection items (e.g., items, comments) is granted by checking permissions on the parent document. This ensures a consistent security model throughout the document tree.
 * - **Default Deny**: Any access not explicitly granted by these rules is denied.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * Use for checking ownership of a resource.
     * @param userId The UID of the user to check against.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Returns true if the user is an owner AND the document already exists.
     * Use for secure update and delete operations.
     * @param userId The UID of the user to check against.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Returns true if the user has the 'Compras' role.
     * This is determined by the existence of a document in the /roles/compras collection.
     * This is highly performant as it avoids a full document read.
     */
    function isCompras() {
      return exists(/databases/$(database)/documents/roles/compras/$(request.auth.uid));
    }
    
    /**
     * Checks if the user is authorized to read a Purchase Request.
     * A user can read if they are the original requester or have the 'Compras' role.
     * Requires a 'get' call to the parent document.
     */
    function canAccessPurchaseRequest(purchaseRequestId) {
        let purchaseRequest = get(/databases/$(database)/documents/purchaseRequests/$(purchaseRequestId)).data;
        return isOwner(purchaseRequest.requesterId) || isCompras();
    }
    
    /**
     * Checks if the user is authorized to read a Purchase Order.
     * A user can read if they are the original requester or have the 'Compras' role.
     * Requires a 'get' call to the parent document.
     */
    function canReadPurchaseOrder(purchaseOrderId) {
        let purchaseOrder = get(/databases/$(database)/documents/purchaseOrders/$(purchaseOrderId)).data;
        return isOwner(purchaseOrder.requesterId) || isCompras();
    }

    /**
     * Checks if the user is authorized to write to a Purchase Order or its subcollections.
     * Only users with the 'Compras' role can modify purchase orders.
     */
    function canWritePurchaseOrder() { // Removed unused purchaseOrderId parameter
        // No get() needed as only the 'Compras' role can ever write to a Purchase Order.
        return isCompras();
    }


    // ----------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------

    /**
     * @description Manages user profile data.
     * @path /userProfiles/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @allow (get, update, delete) The user who owns the profile can read, update, or delete it.
     * @deny (list) Listing all user profiles is disallowed to prevent data enumeration.
     * @deny (get) A user cannot read another user's profile.
     * @principle Restricts access to a user's own data tree (Ownership).
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Read-only collection for 'Compras' role verification.
     * @path /roles/compras/{userId}
     * @allow (get, list) Any signed-in user can check who is in the 'Compras' role.
     * @deny (create, update, delete) All client-side writes are blocked. This collection should only be managed by a trusted backend (e.g., Cloud Function).
     * @principle Segregates authorization data and protects it from client modification.
     */
    match /roles/compras/{userId} {
      allow get, list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Generic rule for master data collections.
     * @path /{collection}/{docId} where collection is one of [proveedores, cuentas, presupuestos, centrosNegocios, centrosCostos]
     * @allow (get, list) Any authenticated user can read this master data (e.g., for dropdowns).
     * @allow (write) Only 'Compras' members can manage master data.
     * @principle Centralized management of non-sensitive, shared data.
     */
    match /{collection}/{docId} where collection in ['proveedores', 'cuentas', 'presupuestos', 'centrosNegocios', 'centrosCostos'] {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isCompras();
    }
    
    /**
     * @description Manages purchase requests created by 'Solicitante' users.
     * @path /purchaseRequests/{purchaseRequestId}
     * @allow (create) A signed-in user can create a request, correctly identifying themselves as the requester.
     * @allow (get, update, delete) The requester or a 'Compras' member can access or modify the request.
     * @allow (list) Any signed-in user can list requests; client-side queries must filter for security.
     * @deny (create) A user cannot create a request on behalf of someone else.
     * @principle Enforces a shared access model between the document owner ('requesterId') and admin-level roles ('Compras').
     */
    match /purchaseRequests/{purchaseRequestId} {
      allow get: if isSignedIn() && (isOwner(resource.data.requesterId) || isCompras());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.requesterId;
      allow update, delete: if resource != null && (isOwner(resource.data.requesterId) || isCompras());
    }

    /**
     * @description Items associated with a specific purchase request.
     * @path /purchaseRequests/{purchaseRequestId}/items/{itemId}
     * @allow (all) Access is granted if the user has permission to access the parent purchase request.
     * @deny (all) A user without access to the parent purchase request cannot interact with its items.
     * @principle Inherits permissions from the parent document to ensure data consistency.
     */
    match /purchaseRequests/{purchaseRequestId}/items/{itemId} {
      allow get, list: if canAccessPurchaseRequest(purchaseRequestId);
      allow create: if canAccessPurchaseRequest(purchaseRequestId) && request.resource.data.purchaseRequestId == purchaseRequestId;
      allow update, delete: if canAccessPurchaseRequest(purchaseRequestId) && resource != null;
    }

    /**
     * @description Comments associated with a specific purchase request.
     * @path /purchaseRequests/{purchaseRequestId}/comments/{commentId}
     * @allow (create) A user with access to the parent request can add a comment.
     * @allow (update, delete) The author of the comment or a 'Compras' member can modify/delete it.
     * @deny (update, delete) A requester cannot modify a comment left by a 'Compras' member.
     * @principle Granular control for subcollection writes, distinguishing between creating and modifying.
     */
    match /purchaseRequests/{purchaseRequestId}/comments/{commentId} {
      allow get, list: if canAccessPurchaseRequest(purchaseRequestId);
      allow create: if canAccessPurchaseRequest(purchaseRequestId) && request.resource.data.commenterId == request.auth.uid && request.resource.data.purchaseRequestId == purchaseRequestId;
      allow update, delete: if resource != null && (isOwner(resource.data.commenterId) || isCompras());
    }
    
    /**
     * @description Manages formal purchase orders generated from approved requests.
     * @path /purchaseOrders/{purchaseOrderId}
     * @allow (create) Only a 'Compras' member can create a purchase order.
     * @allow (get, list) The original requester and 'Compras' members can view purchase orders.
     * @allow (update, delete) Only 'Compras' members can modify or delete purchase orders.
     * @deny (create, update, delete) 'Solicitante' users have read-only access.
     * @principle Enforces strict role-based permissions for a critical workflow step.
     */
    match /purchaseOrders/{purchaseOrderId} {
      allow get: if isSignedIn() && (isOwner(resource.data.requesterId) || isCompras());
      allow list: if isSignedIn();
      allow create: if isCompras() && isOwner(request.resource.data.issuedByUserId);
      allow update, delete: if resource != null && isCompras();
    }

    /**
     * @description Items associated with a specific purchase order.
     * @path /purchaseOrders/{purchaseOrderId}/items/{poItemId}
     * @allow (get, list) The original requester and 'Compras' members can view items.
     * @allow (create, update, delete) Only 'Compras' members can add or modify items on a purchase order.
     * @deny (write) 'Solicitante' users cannot modify the contents of a purchase order.
     * @principle Inherits and enforces permissions from the parent purchase order document.
     */
    match /purchaseOrders/{purchaseOrderId}/items/{poItemId} {
      allow get, list: if canReadPurchaseOrder(purchaseOrderId);
      allow create: if canWritePurchaseOrder() && request.resource.data.purchaseOrderId == purchaseOrderId; // Updated call
      allow update, delete: if canWritePurchaseOrder() && resource != null; // Updated call
    }
  }
}
